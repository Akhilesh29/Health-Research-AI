# Database
DATABASE_URL="postgresql://user:password@localhost:5432/healthguide"

# JWT
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRES_IN="7d"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"

# Groq (OpenAI-compatible)
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# AI (optional)
# Set to "true" to bypass Anthropic and use mock AI analysis responses.
AI_MOCK="false"

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
